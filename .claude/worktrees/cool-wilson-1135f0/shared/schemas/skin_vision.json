{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skin_vision",
  "title": "SkinVisionOutput",
  "description": "Structured output from the Skin Vision Agent. Descriptive only — not diagnostic.",
  "type": "object",
  "required": ["image_quality", "zones", "top_concerns", "disclaimer"],
  "properties": {
    "image_quality": {
      "type": "object",
      "required": ["usable", "issues", "confidence"],
      "properties": {
        "usable": { "type": "boolean" },
        "issues": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["too_dark", "too_bright", "blurry", "face_not_detected", "partial_face", "obstructed"]
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "zones": {
      "type": "object",
      "properties": {
        "forehead":  { "$ref": "#/definitions/Zone" },
        "nose":      { "$ref": "#/definitions/Zone" },
        "cheeks":    { "$ref": "#/definitions/Zone" },
        "under_eye": { "$ref": "#/definitions/Zone" },
        "chin":      { "$ref": "#/definitions/Zone" },
        "jawline":   { "$ref": "#/definitions/Zone" }
      }
    },
    "top_concerns": {
      "type": "array",
      "maxItems": 5,
      "items": { "$ref": "#/definitions/Concern" }
    },
    "disclaimer": {
      "type": "string",
      "const": "This is a visual observation, not a medical diagnosis."
    }
  },
  "definitions": {
    "ConcernType": {
      "type": "string",
      "enum": [
        "dehydration",
        "oiliness",
        "redness",
        "enlarged_pores",
        "uneven_tone",
        "hyperpigmentation",
        "dark_circles",
        "dullness",
        "fine_lines",
        "rough_texture",
        "occasional_breakout",
        "congestion",
        "flaking",
        "visible_sensitivity"
      ]
    },
    "Severity": {
      "type": "string",
      "enum": ["mild", "moderate", "pronounced"]
    },
    "Concern": {
      "type": "object",
      "required": ["type", "severity", "confidence"],
      "properties": {
        "type":       { "$ref": "#/definitions/ConcernType" },
        "severity":   { "$ref": "#/definitions/Severity" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Zone": {
      "type": "object",
      "required": ["concerns"],
      "properties": {
        "concerns": {
          "type": "array",
          "items": { "$ref": "#/definitions/Concern" }
        }
      }
    }
  }
}
